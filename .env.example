# ─── QR Store Mate — environment ──────────────────────────────────────────────
# Copy to .env.local and fill in your Supabase project values.
# Only NEXT_PUBLIC_* vars are needed by the app; both are safe to expose to the
# browser (the anon key is RLS-gated — see the security model in the README).

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
